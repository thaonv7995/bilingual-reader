{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://books-html.local/schemas/book.json",
  "title": "Book workspace manifest",
  "type": "object",
  "required": ["slug", "source_lang", "page_count"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "slug": { "type": "string" },
    "title": { "type": "string" },
    "source_pdf": { "type": "string", "default": "source/original.pdf" },
    "page_count": { "type": "integer", "minimum": 1 },
    "source_lang": { "type": "string", "pattern": "^[a-z]{2}(-[A-Z]{2})?$" },
    "languages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "role"],
        "properties": {
          "code": { "type": "string" },
          "role": { "enum": ["primary", "translation"] },
          "from": { "type": "string" }
        }
      }
    },
    "paths": {
      "type": "object",
      "properties": {
        "work": { "type": "string" },
        "pages": { "type": "string" },
        "meta": { "type": "string" },
        "assets": { "type": "string" },
        "output": { "type": "string" }
      }
    },
    "skills_version": { "type": "string" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": true
}
